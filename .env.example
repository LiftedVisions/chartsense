# Supabase (Auth) — Dashboard → Settings → API
# Project URL: https://<project-ref>.supabase.co
# Key: publishable (sb_publishable_…) or legacy anon JWT — both work with @supabase/supabase-js
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Anthropic — server only (Vercel env + local API). Never VITE_* — keeps key off the client bundle.
ANTHROPIC_API_KEY=

# Optional: override local API proxy target (default http://localhost:8787)
# VITE_API_PROXY=http://localhost:8787
